rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Default Deny Catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // GLOBAL HELPERS
    // ===============================================================
    
    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function getMyData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'Bambangnurdiann@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getMyData().level == 'super_admin')
      );
    }

    function isAdmin() {
      return isSignedIn() && (
        isSuperAdmin() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getMyData().level == 'admin')
      );
    }

    function isPimpinan() {
      return isSignedIn() && (
        isSuperAdmin() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getMyData().level == 'pimpinan')
      );
    }

    function isAuthor() {
      return incoming().pengolah == request.auth.uid;
    }

    // ===============================================================
    // COLLECTION MATCH BLOCKS
    // ===============================================================

    // Users
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // Klasifikasi
    match /klasifikasi/{id} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || isAdmin();
    }

    // Surat Masuk
    match /suratMasuk/{id} {
      allow read: if isSignedIn();
      allow create: if (isAdmin() || isSuperAdmin()) && isAuthor();
      allow update: if isAdmin() || isPimpinan() || isSuperAdmin();
      allow delete: if isSuperAdmin();

      // Disposisi Subcollection
      match /disposisi/{disposisiId} {
        allow read: if isSignedIn();
        allow create: if (isAdmin() || isPimpinan() || isSuperAdmin()) && isAuthor();
        allow update: if isAdmin() || isPimpinan() || isSuperAdmin() || (isSignedIn() && existing().tujuanDisposisi == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['catatan', 'updatedAt']));
        allow delete: if isAdmin() || isPimpinan() || isSuperAdmin();
      }
    }

    // Surat Keluar
    match /suratKeluar/{id} {
      allow read: if isSignedIn();
      allow create: if (isAdmin() || isSuperAdmin()) && isAuthor();
      allow update: if isAdmin() || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // Surat Keputusan (SK)
    match /suratKeputusan/{id} {
      allow read: if isSignedIn();
      allow create: if (isAdmin() || isSuperAdmin()) && isAuthor();
      allow update: if isAdmin() || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // Instansi
    match /instansi/{id} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }
  }
}
